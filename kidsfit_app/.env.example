# KidsFit App Environment Configuration
# Development Environment

# API Configuration
API_BASE_URL=https://api-dev.kidsfit.cn
API_TIMEOUT=30000

# WebSocket Configuration
WS_URL=wss://ws-dev.kidsfit.cn

# Storage Keys
STORAGE_TOKEN_KEY=kidsfit_token
STORAGE_USER_KEY=kidsfit_user
STORAGE_SETTINGS_KEY=kidsfit_settings

# Feature Flags
ENABLE_DEBUG_MODE=true
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=true

# AI Configuration
POSE_DETECTION_MODEL=base
POSE_DETECTION_CONFIDENCE_THRESHOLD=0.5

# Cache Configuration
CACHE_MAX_SIZE=100
CACHE_EXPIRY_HOURS=24

# Logging
LOG_LEVEL=debug
LOG_FILE_ENABLED=false
